# backend/.env — loaded by pydantic-settings at startup and by docker-compose via env_file.
# Real environment variables set on the host always override values in this file.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_db

# Signs all JWT tokens. A weak secret makes the entire authentication system bypassable.
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Authenticates requests to the Gemini API. Empty value causes all AI calls to return 401.
GEMINI_API_KEY=<your-gemini-api-key-here>
GEMINI_MODEL=gemini-2.5-flash

# The "models/" prefix is required by the Gemini embedding API endpoint path.
GEMINI_EMBEDDING_MODEL=models/embedding-001

# Browsers block cross-origin fetch unless this matches the URL the frontend is served from.
ALLOWED_ORIGINS=http://localhost:3000

ENVIRONMENT=development
