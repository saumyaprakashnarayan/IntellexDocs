# Root .env — read by Docker Compose for ${VAR} substitution in docker-compose.yml.
# Values set here take precedence over backend/.env for variables that appear in both.
# This file is gitignored. The .env.example version is committed instead.

# Postgres authenticates the backend connection with these credentials.
# Both the postgres service and the DATABASE_URL must agree on these values.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_db

# Signs every JWT token. A leaked or weak secret lets anyone forge authentication tokens.
JWT_SECRET=change-me-before-production

# Authenticates every request to the Gemini API.
# An empty or invalid key causes all LLM and embedding calls to fail with 401.
GEMINI_API_KEY=<your-gemini-api-key-here>

# URL the browser uses to reach the backend.
# Because the browser makes the call (not the container), this is always the host-visible URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Controls which frontend origins the backend's CORS middleware accepts.
# A mismatch here causes the browser to silently block API responses.
ALLOWED_ORIGINS=http://localhost:3000

# Selects the Gemini chat model. Flash is faster and cheaper; Pro is more capable.
GEMINI_MODEL=gemini-2.5-flash

# Must include the "models/" prefix required by the Gemini embedding API.
GEMINI_EMBEDDING_MODEL=models/embedding-001

GEMINI_EMBEDDING_MODEL=models/embedding-001
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development
