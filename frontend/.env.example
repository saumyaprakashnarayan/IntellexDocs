# frontend/.env.local — loaded by Next.js development server automatically.
# Variables prefixed with NEXT_PUBLIC_ are inlined into the browser bundle
# at build time, making them accessible in client-side JavaScript.
# Variables without the prefix exist only server-side and never reach the browser.

# The URL the browser sends API requests to.
# Changing this value requires a rebuild (`npm run build`) because
# Next.js bakes NEXT_PUBLIC_ variables into the compiled JavaScript.
NEXT_PUBLIC_API_URL=http://localhost:8000
